{
  "name": "@ud2/server-list-ping",
  "exports": "./mod.ts",
  "imports": {
    "@ud2/binio": "jsr:@ud2/binio@^0.3.0"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "deno.shared_globals"
    ],
    "exactOptionalPropertyTypes": true
  },
  "publish": {
    "exclude": [
      ".github",
      "deno.lock",
      "**/test.ts",
      "**/*_test.ts"
    ]
  },
  "tasks": {
    "cache": "deno cache --allow-import=jsr.io:443 main.ts",
    "lint": "deno fmt --check && deno lint --allow-import=jsr.io:443 && deno check --allow-import=jsr.io:443 main.ts",
    "test": "deno test --allow-import=jsr.io:443"
  }
}
